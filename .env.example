# Local development environment template for LeythersCom
# Copy this file to .env and set real values.
# Do not commit your .env file.

# Phoenix
PHX_SERVER=true
PHX_HOST=localhost
PORT=4000

# Database
DATABASE_URL=ecto://postgres:postgres@localhost/leythers_com_dev
DATABASE_SSL=false
POOL_SIZE=10
DB_USE_UNNAMED_PREPARE=true
DB_QUEUE_TARGET_MS=5000
DB_QUEUE_INTERVAL_MS=20000

# LLM runtime
# Dev startup provider; can later be switched in-app via
# LeythersCom.Intelligence.set_dev_llm_provider/1
DEV_LLM_PROVIDER=ollama

# Production provider gate (prod accepts openrouter only)
LLM_PROVIDER=openrouter

# Shared LLM tuning
LLM_TEMPERATURE=0.4
LLM_NUM_PREDICT=600
LLM_TIMEOUT_MS=30000
LLM_LOG_REQUESTS=false

# OpenRouter profile
OPENROUTER_API_KEY=replace_me
OPENROUTER_API_ENDPOINT=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_HTTP_REFERER=http://localhost:4000
OPENROUTER_SITE_NAME=LeythersCom

# Ollama profile
OLLAMA_API_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
